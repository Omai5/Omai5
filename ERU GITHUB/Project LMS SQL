--Report 1: Total books per category--
select Category_Name, count(Book_ID) as TotalBooks
from Book
join Category on Book.Category_ID = Category.Category_ID
group by Category_Name

--Report 2: Members who have fines--
select First_Name, Last_Name, FineAmount
from Member
join Borrow on Member.Member_ID = Borrow.Member_ID
where FineAmount > 0

--Report 3: Average fine per member type--
select MemberType, avg(FineAmount) as AvgFine
from Member
join Borrow on Member.Member_ID = Borrow.Member_ID
group by MemberType

--Report 4: Members with fines (Nested)--
select First_Name, Last_Name
from Member
where Member_ID in (
    select Member_ID 
    from Borrow 
    where FineAmount > 0
)
