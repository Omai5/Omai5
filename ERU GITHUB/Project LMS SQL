--borrow book procedure (Dynamic)--
create proc sp_borrow_book
    @Book_ID as int,
    @Member_ID as int,
    @Price as decimal(6,2)
as
begin

    declare @Due_Date as date
    declare @Borrow_Date as date = getdate()
    declare @MaxBooks as int

    select 
        @Due_Date = case MemberType
            when 'Premium' then dateadd(day, 30, getdate())
            else dateadd(day, 7, getdate())
        end,
        @MaxBooks = case MemberType
            when 'Premium' then 10
            else 3
        end
    from Member
    where Member_ID = @Member_ID

    insert into Borrow values
    (@Member_ID, @Book_ID, @Borrow_Date, @Due_Date, 0, @Price, @MaxBooks)

end

exec sp_borrow_book 1, 2, 250
exec sp_borrow_book 3, 11, 350


--upgrade member to premium (Dynamic)--
create proc sp_upgrade_member
    @Member_ID as int,
    @SubscriptionFee as decimal(8,2)
as
begin

    update Member
    set MemberType = 'Premium',
        SubscriptionFee = @SubscriptionFee,
        SubscriptionExpiry = dateadd(year, 1, getdate())
    where Member_ID = @Member_ID
    and MemberType = 'Regular'

end

exec sp_upgrade_member 1, 200.00


--check expired memberships (Static)--
create proc sp_check_membership
as
begin

    update Member
    set MemberType = 'Regular',
        SubscriptionFee = null,
        SubscriptionExpiry = null
    where MemberType = 'Premium'
    and SubscriptionExpiry < getdate()

end

exec sp_check_membership
